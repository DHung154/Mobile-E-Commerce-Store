@model HiTechShop.Models.ChangePasswordViewModel

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-lg rounded-4">
                <div class="card-header bg-primary bg-gradient text-white p-4">
                    <h4 class="mb-0 fw-bold"><i class="fas fa-key me-2"></i>Đổi mật khẩu</h4>
                </div>
                <div class="card-body p-4">
                    @using (Html.BeginForm("ChangePassword", "User", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger small mb-3" })

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">MẬT KHẨU HIỆN TẠI</label>
                            @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control rounded-pill border-light-subtle shadow-sm px-3", placeholder = "********" })
                            @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold">MẬT KHẨU MỚI</label>
                            @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control rounded-pill border-light-subtle shadow-sm px-3", placeholder = "Tối thiểu 6 ký tự" })
                            @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-muted small fw-bold">XÁC NHẬN MẬT KHẨU MỚI</label>
                            @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control rounded-pill border-light-subtle shadow-sm px-3", placeholder = "Nhập lại mật khẩu mới" })
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "text-danger small" })
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill py-2 shadow-sm fw-bold">
                                <i class="fas fa-save me-2"></i>Cập nhật mật khẩu
                            </button>
                            <a href="@Url.Action("Profile", "User")" class="btn btn-link text-decoration-none text-muted">
                                Quay lại trang cá nhân
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f0f2f5;
    }

    .card {
        border-radius: 15px;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.1);
    }

    .bg-primary.bg-gradient {
        background: linear-gradient(45deg, #0d6efd, #0099ff) !important;
    }
</style>
@model HiTechShop.Models.UserOrdersViewModel
@{
    ViewBag.Title = "Chi tiết đơn hàng";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h3 class="fw-bold mb-0">📄 Chi tiết đơn hàng #@(Model.DonHang?.MaDH ?? 0)</h3>
        </div>
        <div class="card-body">
            @if (Model.DonHang != null)
            {
                <p><strong>Ngày đặt:</strong> @(Model.DonHang.NgayDat.HasValue ? Model.DonHang.NgayDat.Value.ToString("dd/MM/yyyy") : "N/A")</p>

                <table class="table table-bordered table-hover">
                    <thead class="table-light text-center">
                        <tr>
                            <th>Hình</th>
                            <th>Sản phẩm</th>
                            <th>Số lượng</th>
                            <th>Giá</th>
                            <th>Tổng</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.ChiTiet != null && Model.ChiTiet.Any())
                        {
                            foreach (var sp in Model.ChiTiet)
                            {
                                <tr>
                                    <td width="80" class="text-center">
                                        <img src="~/Content/images/@(sp.SanPham?.HinhAnh ?? "no-image.png")" width="70" class="img-thumbnail" />
                                    </td>
                                    <td>@(sp.SanPham?.TenSP ?? "Sản phẩm không tồn tại")</td>
                                    <td class="text-center">@sp.SoLuong</td>
                                    <td class="text-end">@((sp.DonGia ?? 0).ToString("N0")) đ</td>
                                    <td class="text-end font-weight-bold">
                                        @(((sp.SoLuong ?? 0) * (sp.DonGia ?? 0)).ToString("N0")) đ
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>

                <div class="text-end mt-3">
                    <p class="fs-5">
                        Tổng đơn: <strong class="text-danger">@(Model.DonHang.TongTien?.ToString("N0") ?? "0") đ</strong>
                    </p>
                </div>
            }
            else
            {
                <div class="alert alert-warning">Không tìm thấy thông tin đơn hàng.</div>
            }
        </div>
    </div>
</div>
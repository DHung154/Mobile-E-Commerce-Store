@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Tham gia cùng HiTech Shop</title>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link href="~/CSS/SaoRoi.css" rel="stylesheet" />

    <style>
        :root {
            --glass-bg: rgba(255, 255, 255, 0.12);
            --glass-border: rgba(255, 255, 255, 0.2);
            --primary-gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --accent-color: #00d4ff;
        }

        body {
            font-family: 'Inter', sans-serif;
            margin: 0;
            background: #0f0c29; /* Fallback background */
            overflow-x: hidden;
        }

        .register-container {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 2rem;
            position: relative;
            z-index: 2;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 24px;
            padding: 40px;
            width: 100%;
            max-width: 550px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            transition: transform 0.4s ease;
        }

            .glass-card:hover {
                border-color: rgba(255, 255, 255, 0.4);
            }

        .brand-logo {
            font-weight: 800;
            letter-spacing: -1px;
            background: linear-gradient(to right, #fff, var(--accent-color));
            -webkit-text-fill-color: transparent;
            font-size: 1.5rem;
        }

        .form-label {
            font-weight: 500;
            color: rgba(255, 255, 255, 0.9);
            font-size: 0.85rem;
            margin-left: 4px;
        }

        .input-group-text {
            background: rgba(255, 255, 255, 0.05);
            border: 1px solid var(--glass-border);
            color: rgba(255, 255, 255, 0.6);
            border-radius: 12px 0 0 12px;
        }

        .form-control, .form-select {
            background: rgba(255, 255, 255, 0.15); /* Tăng độ sáng nền */
            border: 1px solid rgba(255, 255, 255, 0.3); /* Viền rõ hơn */
            color: #ffffff !important; /* Chữ trắng đậm */
            padding: 12px 16px;
            border-radius: 12px;
            transition: all 0.3s ease;
        }

            .form-select option {
                background-color: #1a1a2e; /* Màu nền tối cho dropdown */
                color: #ffffff; /* Chữ trắng rõ ràng */
            }

            .form-control:focus, .form-select:focus {
                background: rgba(255, 255, 255, 0.25); /* Sáng hẳn lên khi gõ */
                border-color: var(--accent-color);
                box-shadow: 0 0 0 4px rgba(0, 212, 255, 0.2);
                outline: none;
            }

            .form-control::placeholder {
                color: rgba(255, 255, 255, 0.6) !important;
            }

        input[type="date"]::-webkit-calendar-picker-indicator {
            filter: invert(1); /* Chuyển icon lịch sang màu trắng */
            cursor: pointer;
        }

        .btn-register {
            background: var(--primary-gradient);
            border: none;
            border-radius: 12px;
            padding: 14px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: white;
            margin-top: 1rem;
            transition: all 0.3s ease;
        }

            .btn-register:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(118, 75, 162, 0.4);
                filter: brightness(1.1);
            }

        .back-link {
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            font-size: 0.9rem;
            transition: 0.3s;
        }

            .back-link:hover {
                color: #fff;
            }

        /* Tối ưu hóa cho Mobile */
        @@media (max-width: 576px) {
            .glass-card {
                padding: 25px;
            }
        }
    </style>
</head>
<body>

    <div class="night">
        @for (int i = 0; i < 20; i++)
        {<div class="shooting_star"></div>}
    </div>

    <div class="register-container">
        @using (Html.BeginForm("RegisterSubmit", "User", FormMethod.Post, new { @class = "w-100", style = "max-width: 550px;" }))
        {
            @Html.AntiForgeryToken()

            <div class="glass-card">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <a href="@Url.Action("Login", "User")" class="back-link">
                        <i class="bi bi-chevron-left me-1"></i> Quay lại
                    </a>
                    <span class="brand-logo">HiTech Shop</span>
                </div>

                <div class="text-center mb-4">
                    <h2 class="text-white fw-bold mb-1">Bắt đầu ngay</h2>
                    <p class="text-white-50 small">Khám phá thế giới công nghệ cùng chúng tôi</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger border-0 bg-danger bg-opacity-25 text-white small mb-4" role="alert">
                        <i class="bi bi-exclamation-circle-fill me-2"></i>@ViewBag.Error
                    </div>
                }

                <div class="row g-3">
                    <div class="col-12">
                        <label class="form-label">Họ và tên</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" name="HoTen" required class="form-control" placeholder="Nhập họ tên đầy đủ" />
                        </div>
                    </div>

                    <div class="col-md-7">
                        <label class="form-label">Số điện thoại</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-phone"></i></span>
                            <input type="tel" name="SoDienThoai" class="form-control" placeholder="09xx xxx xxx" />
                        </div>
                    </div>

                    <div class="col-md-5">
                        <label class="form-label">Giới tính</label>
                        <select name="GioiTinh" class="form-select">
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Ngày sinh</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                            <input type="date" name="NgaySinh" required class="form-control" />
                        </div>
                    </div>

                    <div class="col-12">
                        <label class="form-label">Email đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-envelope-at"></i></span>
                            <input type="email" name="TenDangNhap" required class="form-control" placeholder="name@example.com" />
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Mật khẩu</label>
                        <input type="password" name="MatKhau" required class="form-control" placeholder="••••••••" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label">Xác nhận</label>
                        <input type="password" name="NhapLaiMatKhau" required class="form-control" placeholder="••••••••" />
                    </div>
                </div>

                <button type="submit" class="btn btn-primary btn-register w-100 shadow-lg">
                    Tạo tài khoản <i class="bi bi-arrow-right-short ms-1"></i>
                </button>

                <div class="text-center mt-4">
                    <span class="text-white-50 small">Đã có tài khoản HiTech?</span>
                    <a href="@Url.Action("Login", "User")" class="ms-1 fw-bold text-decoration-none" style="color: var(--accent-color);">Đăng nhập</a>
                </div>
            </div>
        }
    </div>

</body>
</html>
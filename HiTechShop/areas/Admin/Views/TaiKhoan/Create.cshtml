@model HiTechShop.Areas.Admin.Data.TaiKhoanCreateVM
@{
    ViewBag.Title = "Thêm tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">📝 Thêm tài khoản mới</h6>
        </div>
        <div class="card-body">
            @using (Html.BeginForm())
            {
                @Html.AntiForgeryToken()

                @* Hiển thị thông báo lỗi tổng quát từ Server *@
                @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                <div class="row">
                    <div class="form-group col-md-6">
                        <label class="font-weight-bold">Tên đăng nhập</label>
                        @Html.TextBoxFor(m => m.TenDangNhap, new { @class = "form-control", placeholder = "Nhập tên tài khoản..." })
                        @Html.ValidationMessageFor(m => m.TenDangNhap, "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-group col-md-6">
                        <label class="font-weight-bold">Họ tên người dùng</label>
                        @Html.TextBoxFor(m => m.HoTenNguoiDung, new { @class = "form-control", placeholder = "Họ và tên..." })
                    </div>
                </div>

                <div class="row">
                    <div class="form-group col-md-6">
                        <label class="font-weight-bold">Mật khẩu</label>
                        @Html.PasswordFor(m => m.MatKhau, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.MatKhau, "", new { @class = "text-danger small" })
                    </div>

                    <div class="form-group col-md-6">
                        <label class="font-weight-bold">Nhập lại mật khẩu</label>
                        @Html.PasswordFor(m => m.NhapLaiMatKhau, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.NhapLaiMatKhau, "", new { @class = "text-danger small" })
                    </div>
                </div>

                <div class="form-group">
                    <label class="font-weight-bold">Vai Trò</label>
                    @Html.DropDownListFor(m => m.VaiTro, new List<SelectListItem>
                    {
                        new SelectListItem { Text = "Admin", Value = "Admin" },
                        new SelectListItem { Text = "User", Value = "User" }
                    }, "-- Chọn Vai Trò --", new { @class = "form-control" })
                    @Html.ValidationMessageFor(m => m.VaiTro, "", new { @class = "text-danger small" })
                </div>

                <hr />
                <button type="submit" class="btn btn-primary px-4">Thêm mới</button>
                <a href="@Url.Action("Index")" class="btn btn-secondary px-4">Hủy</a>
            }
        </div>
    </div>
</div>
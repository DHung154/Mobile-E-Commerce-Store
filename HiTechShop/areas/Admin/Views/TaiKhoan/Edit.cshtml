@model HiTechShop.Models.TaiKhoan
@{
    ViewBag.Title = "Chỉnh sửa tài khoản";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <div class="card shadow mb-4">
        <div class="card-header py-3">
            <h6 class="m-0 font-weight-bold text-primary">✏️ Chỉnh sửa tài khoản: @Model.TenDangNhap</h6>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Edit", "TaiKhoan", FormMethod.Post))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.MaTK)
                @* Giữ lại MaND để không bị mất liên kết với bảng NguoiDung *@
                @Html.HiddenFor(m => m.MaND)

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="font-weight-bold">Tên Đăng Nhập</label>
                            @Html.TextBoxFor(m => m.TenDangNhap, new { @class = "form-control", @readonly = "readonly" })
                            <small class="text-muted">Không thể thay đổi tên đăng nhập.</small>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="font-weight-bold">Vai Trò</label>
                            @Html.DropDownListFor(m => m.VaiTro, new List<SelectListItem>
                            {
                                new SelectListItem { Text = "Quản trị viên (Admin)", Value = "Admin" },
                                new SelectListItem { Text = "Người dùng (User)", Value = "User" }
                            }, new { @class = "form-control" })
                        </div>
                    </div>
                </div>

                <div class="form-group">
                    <label class="font-weight-bold">Mật khẩu mới</label>
                    <input type="password" name="NewPassword" class="form-control" placeholder="Để trống nếu không muốn đổi mật khẩu" />
                    <small class="text-danger">@Html.ValidationMessage("NewPassword")</small>
                </div>

                <hr />
                <div class="form-group">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="fas fa-save"></i> 💾 Cập nhật
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary px-4">
                        <i class="fas fa-undo"></i> ❌ Hủy
                    </a>
                </div>
            }
        </div>
    </div>
</div>
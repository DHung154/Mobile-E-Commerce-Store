@model HiTechShop.Models.LoaiSP
@{
    ViewBag.Title = "Thêm loại sản phẩm";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="@Url.Action("Index")">Loại sản phẩm</a></li>
            <li class="breadcrumb-item active" aria-current="page">Thêm mới</li>
        </ol>
    </nav>

    <div class="card shadow mb-4">
        <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
            <h6 class="m-0 font-weight-bold text-primary">📝 Thêm loại sản phẩm mới</h6>
        </div>
        <div class="card-body">
            @using (Html.BeginForm("Create", "LoaiSP", FormMethod.Post))
            {
                @Html.AntiForgeryToken()

                @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                <div class="row">
                    @* Tên loại sản phẩm *@
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="font-weight-bold">Tên Loại Sản Phẩm <span class="text-danger">*</span></label>
                            @Html.TextBoxFor(m => m.TenLoai, new { @class = "form-control", placeholder = "Ví dụ: Laptop Gaming, iPhone...", autofocus = "autofocus" })
                            @Html.ValidationMessageFor(m => m.TenLoai, "", new { @class = "text-danger small" })
                        </div>
                    </div>

                    @* Danh mục cha *@
                    <div class="col-md-6">
                        <div class="form-group">
                            <label class="font-weight-bold">Danh Mục <span class="text-danger">*</span></label>
                            @Html.DropDownListFor(m => m.MaDM,
                                (SelectList)ViewBag.MaDM,
                                "-- Chọn danh mục --",
                                new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.MaDM, "", new { @class = "text-danger small" })
                        </div>
                    </div>
                </div>

                <hr />

                <div class="form-group mb-0">
                    <button type="submit" class="btn btn-success shadow-sm px-4">
                        <i class="fas fa-save"></i> ✅ Thêm mới
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-secondary shadow-sm px-4">
                        <i class="fas fa-undo"></i> Quay lại
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    @* Quan trọng: Đảm bảo các file này tồn tại trong thư mục Scripts của dự án *@
    <script src="~/Scripts/jquery.validate.min.js"></script>
    <script src="~/Scripts/jquery.validate.unobtrusive.min.js"></script>
}
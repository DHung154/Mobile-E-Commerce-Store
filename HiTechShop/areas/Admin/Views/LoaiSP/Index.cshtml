@model IEnumerable<HiTechShop.Models.LoaiSP>
@{
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Quản lý loại sản phẩm";
}

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>📦 Quản lý loại sản phẩm</h2>
        <a href="@Url.Action("Create")" class="btn btn-success shadow-sm">
            <i class="fas fa-plus"></i> Thêm loại mới
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <strong>✅ Thành công!</strong> @TempData["SuccessMessage"]
            <button type="button" class="close" data-dismiss="alert">&times;</button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <table class="table table-bordered table-hover mb-0">
                <thead class="thead-light">
                    <tr>
                        <th width="15%">Mã Loại</th>
                        <th width="35%">Tên Loại</th>
                        <th width="30%">Thuộc Danh Mục</th>
                        <th width="20%" class="text-center">Hành Động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu.</td>
                        </tr>
                    }
                    else
                    {
                        @* Đã xóa dấu @ dư thừa ở đây *@
                        foreach (var loai in Model)
                        {
                            <tr>
                                <td class="font-weight-bold text-primary">#@loai.MaLoai</td>
                                <td>@loai.TenLoai</td>
                                <td>
                                    @if (loai.DanhMuc != null)
                                    {
                                        <span class="badge badge-secondary px-3 py-2" style="color: #4e73df; background-color: #f8f9fc; border: 1px solid #d1d3e2;">
                                            <i class="fas fa-folder"></i> @loai.DanhMuc.TenDM
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted italic small">Chưa phân mục</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a class="btn btn-sm btn-warning mr-1" href="@Url.Action("Edit", new { id = loai.MaLoai })">
                                        <i class="fas fa-edit"></i> Sửa
                                    </a>
                                    <a class="btn btn-sm btn-danger" href="@Url.Action("Delete", new { id = loai.MaLoai })"
                                       onclick="return confirm('Xác nhận xóa?')">
                                        <i class="fas fa-trash"></i> Xóa
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>